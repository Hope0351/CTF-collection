# Binary challenge artifacts (not committed — fetch from source repos)
*.pcap
*.pcapng
*.bin
*.elf
*.exe
*.dll
*.so
*.dylib
*.dmp
*.raw
*.img
*.iso
*.vmdk

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/

# Editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Tokens / secrets — NEVER commit
*.token
*.pat
.env
.github_token

# Build artifacts
node_modules/
dist/
build/

# ===================================================================
# Additional CTF binary / artifact patterns (added during archive import)
# ===================================================================
# VM images and kernel artifacts
*.qcow2
*.vdi
*.vhd
*.ova
*.ovf
*.bzImage
*.vmlinuz
*.initramfs
*.cpio

# Compressed handouts (often large)
*.tar.gz
*.tgz
*.tar.bz2
*.tbz2
*.tar.xz
*.txz
*.7z
*.rar
*.lz4
*.zst

# Java / Android
*.jar
*.aar
*.apk
*.dex
*.war

# Database / memory dumps
*.db
*.sqlite
*.sqlite3
*.memdump
*.heapdump
*.hprof

# Model / data files (often >50MB)
*.dat
*.pkl
*.pickle
*.h5
*.pb
*.onnx
*.pt
*.pth
*.ckpt
*.safetensors

# QEMU / emulation binaries
qemu-system-*
qemu_user_*
qemu_*_ai1337

# Stockfish and similar engine binaries
stockfish*

# Pre-built binaries without extension (CTF pwn challenges)
# (We don't blanket-ignore these — they're often the challenge. 
#  Instead, explicit path-based ignores below handle the large ones.)

